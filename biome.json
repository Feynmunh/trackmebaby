{
    "$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "files": {
        "includes": ["**/*"],
        "ignoreUnknown": true
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "complexity": {
                "noBannedTypes": "off"
            },
            "a11y": {
                "noSvgWithoutTitle": "off",
                "useButtonType": "off",
                "noStaticElementInteractions": "off",
                "useKeyWithClickEvents": "off",
                "noLabelWithoutControl": "off"
            },
            "suspicious": {
                "useIterableCallbackReturn": "off",
                "noUnknownAtRules": "off",
                "noArrayIndexKey": "off",
                "noExplicitAny": "error"
            },
            "correctness": {
                "useExhaustiveDependencies": "off",
                "useParseIntRadix": "off"
            },
            "style": {
                "noNonNullAssertion": "off",
                "useTemplate": "off",
                "useImportType": "off"
            }
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "double",
            "semicolons": "always",
            "trailingCommas": "all"
        }
    },
    "overrides": [
        {
            "includes": ["**/*.tsx"],
            "javascript": {
                "jsxRuntime": "reactClassic"
            }
        }
    ]
}
