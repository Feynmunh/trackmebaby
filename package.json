{
    "name": "trackmebaby",
    "version": "0.1.0",
    "description": "A background desktop app that watches your projects folder and keeps track of what you're working on",
    "scripts": {
        "dev": "electrobun build && concurrently \"bun run dev:ui\" \"bun run dev:native\"",
        "dev:ui": "vite --port 5173",
        "dev:native": "electrobun dev --watch",
        "build": "vite build && electrobun build",
        "build:prod": "vite build && electrobun build --env=stable",
        "preview": "bun run build && electrobun dev",
        "start": "bun run dev",
        "lint": "biome check .",
        "format": "biome format .",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@google/genai": "^1.44.0",
        "@parcel/watcher-wasm": "^2.5.6",
        "@pierre/diffs": "^1.0.11",
        "electrobun": "1.13.1",
        "ignore": "^7.0.5",
        "lucide-react": "^0.575.0",
        "motion": "^12.34.3",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-markdown": "^10.1.0",
        "remark-gfm": "^4.0.1"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.4",
        "@types/bun": "latest",
        "@types/node": "^25.5.0",
        "@types/react": "^18.3.12",
        "@types/react-dom": "^18.3.1",
        "@vitejs/plugin-react": "^4.3.4",
        "autoprefixer": "^10.4.20",
        "concurrently": "^9.1.0",
        "postcss": "^8.4.49",
        "tailwindcss": "^3.4.16",
        "typescript": "^5.7.2",
        "vite": "^6.0.3"
    }
}
